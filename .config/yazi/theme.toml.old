# : Manager [[[

[mgr]
cwd = { fg = "#ece1d4" }

# Find
find_keyword  = { fg = "#ffb4ab", bold = true, italic = true, underline = true }
find_position = { fg = "#ffb4ab", bold = true, italic = true }

# Marker
marker_copied   = { fg = "#9ad172", bg = "#9ad172" }
marker_cut      = { fg = "#d1eabf", bg = "#d1eabf" }
marker_marked   = { fg = "#ffb4ab", bg = "#ffb4ab" }
marker_selected = { fg = "#b5cea4", bg = "#b5cea4" }

# Count
count_copied   = { fg = "#0d2005", bg = "#d1eabf" }
count_cut      = { fg = "#0d2005", bg = "#d1eabf" }
count_selected = { fg = "#432c00", bg = "#b5cea4" }

# Border
border_symbol = "│"
border_style  = { fg = "#f0be6d" }

# : ]]]


# : Indicator [[[

[indicator]
padding = { open = "█", close = "█" }

# : ]]]


# : Tabs [[[

[tabs]
active    = { fg = "#f0be6d", bold = true, bg = "#18130b" }
inactive  = { fg = "#dbc3a1", bg = "#18130b" }
sep_inner = { open = "[", close = "]" }

# : ]]]


# : Mode [[[

[mode]
# Mode
normal_main = { bg = "#f0be6d", fg = "#432c00", bold = true }
normal_alt  = { bg = "#4e4539", fg = "#d2c4b4" }

# Select mode
select_main = { bg = "#dbc3a1", fg = "#3d2e16", bold = true }
select_alt  = { bg = "#4e4539", fg = "#d2c4b4" }

# Unset mode
unset_main = { bg = "#b5cea4", fg = "#223618", bold = true }
unset_alt  = { bg = "#4e4539", fg = "#d2c4b4" }

# : ]]]


# : Status [[[

[status]
sep_left  = { open = "🭁", close = "🭠" }
sep_right = { open = "🭁", close = "🭠" }

# Permissions
perm_type  = { fg = "#a47a3f" }
perm_write = { fg = "#668d4c" }
perm_read  = { fg = "#ff2b12" }
perm_exec  = { fg = "#7ec44c" }
perm_sep   = { fg = "#ffa014" }

# Progress
progress_label  = { bold = true }
progress_normal = { fg = "#f0be6d", bg = "#3f382f" }
progress_error  = { fg = "#ffb4ab", bg = "#3f382f" }

# : ]]]


# : Which [[[

[which]
cols = 3
mask = { bg = "#3f382f" }
cand = { fg = "#f0be6d" }
rest = { fg = "#432c00" }
desc = { fg = "#ece1d4" }
separator = " ▶ "
separator_style = { fg = "#ece1d4" }

# : ]]]


# : Notify [[[

[notify]
title_info  = { fg = "#b5cea4" }
title_warn  = { fg = "#f0be6d" }
title_error = { fg = "#ffb4ab" }

# : ]]]


# : Picker [[[

[pick]
border = { fg = "#f0be6d" }
active = { fg = "#b5cea4", bold = true }
inactive = {}

# : ]]]


# : Input [[[

[input]
border = { fg = "#f0be6d" }
value  = { fg = "#ece1d4" }

# : ]]]


# : Completion [[[

[cmp]
border = { fg = "#f0be6d", bg = "#432c00" }

# : ]]]


# : Tasks [[[

[tasks]
border  = { fg = "#f0be6d" }
title   = {}
hovered = { fg = "#d1eabf", underline = true }

# : ]]]


# : Help [[[

[help]
on     = { fg = "#ece1d4" }
run    = { fg = "#ece1d4" }
footer = { fg = "#3d2e16", bg = "#dbc3a1" }

# : ]]]


# : File-specific styles [[[

[filetype]

rules = [
    # Images
    { mime = "image/*", fg = "#94e2d5" },

    # Media
    { mime = "{audio,video}/*", fg = "#f9e2af" },

    # Archives
    { mime = "application/{zip,rar,7z*,tar,gzip,xz,zstd,bzip*,lzma,compress,archive,cpio,arj,xar,ms-cab*}", fg = "#f5c2e7" },

    # Documents
    { mime = "application/{pdf,doc,rtf}", fg = "#a6e3a1" },

    # Special files
    { name = "*", is = "orphan", bg = "#93000a" },
    { name = "*", is = "exec", fg = "#ffdad6" },

    # Fallback
    { url = "*", fg = "#ece1d4" },
    { url = "*/", fg = "#f0be6d" },
]

# : ]]]
